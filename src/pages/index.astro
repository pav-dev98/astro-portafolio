---
import Layout from "../layout/layout.astro";
import { Hero } from "../components/Hero";
import Stack from "../components/Stack";
---

<Layout title="_hello">
	<!-- <div class="aviso">
		🔨 This page is under construction
	</div> -->
    <div class="hero">
        <Hero client:load />
        <!-- <ProjectList client:idle /> -->
        <div id="stack-cards-id">
            <Stack
            client:load
            randomRotation={false}
            sensitivity={200}
            sendToBackOnClick={true}
            autoplay={false}
            autoplayDelay={3000}
            pauseOnHover={false}
            />
        </div>
    </div>
</Layout>
<style>
.layout > main > .aviso{
        position: absolute;
        top: 24px;
        left: 0;
        background-color: black;
        width: 100%;
        padding: 1rem 2rem;
    }
.hero{
        display: flex;
        flex-direction: column;
        justify-content: center;
        height: 100%;
        padding: 2rem;
    }
    #stack-cards-id {
        width: 100%;
        height: 400px;
    }
 @media (min-width: 768px) {
    .hero {
        flex-direction: row;
        justify-content: center;
        align-items: center;
        gap: 6rem;
    }
    #stack-cards-id {
        width: 400px !important;
    }
 }
</style>
